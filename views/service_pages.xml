<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Accounting Service Page - Meridian Style -->
    <template id="service_accounting_page" name="Accounting &amp; Tax Service">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'service-accounting'"/>
            
            <div id="wrap">
                <!-- Hero Section -->
                <section class="hero-section bg-navy">
                    <div class="hero-overlay"></div>
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-6 hero-content">
                                <div class="hero-tags">
                                    <span t-translation="on">Accounting</span>
                                    <span t-translation="on">Tax</span>
                                    <span t-translation="on">Compliance</span>
                                </div>
                                
                                <h1 class="hero-title">
                                    <span t-translation="on">Accounting setup</span><br/>
                                    <span class="text-coral" t-translation="on">with Odoo.</span>
                                </h1>
                                
                                <p class="hero-description" t-translation="on">
                                    Chart of accounts, tax structure, multi-entity, and reporting 
                                    tailored to your business — implemented on Odoo with discipline.
                                </p>
                                
                                <div class="hero-buttons">
                                    <a href="/appointment/1" class="btn-primary-coral" t-translation="on">
                                        Book a consultation
                                    </a>
                                    <a href="#features" class="btn-outline-light" t-translation="on">
                                        Learn more <span class="arrow">→</span>
                                    </a>
                                </div>
                            </div>
                            
                            <div class="col-lg-5 offset-lg-1">
                                <div class="hero-stats">
                                    <div class="stat-item">
                                        <div class="stat-value">75%</div>
                                        <div class="stat-label" t-translation="on">faster month-end close</div>
                                    </div>
                                    <div class="stat-item">
                                        <div class="stat-value">100%</div>
                                        <div class="stat-label" t-translation="on">tax compliance</div>
                                    </div>
                                    <div class="stat-item">
                                        <div class="stat-value">1.2k</div>
                                        <div class="stat-label" t-translation="on">entries automated</div>
                                    </div>
                                    <div class="stat-item">
                                        <div class="stat-value">24/7</div>
                                        <div class="stat-label" t-translation="on">financial visibility</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Features Section -->
                <section class="modulio-section bg-cream" id="features">
                    <div class="container">
                        <div class="row mb-5">
                            <div class="col-lg-5">
                                <span class="section-label" t-translation="on">Features</span>
                                <h2 class="section-title" t-translation="on">
                                    What's included in our accounting implementation.
                                </h2>
                            </div>
                            <div class="col-lg-6 offset-lg-1 d-flex align-items-center">
                                <p class="section-subtitle mb-0" t-translation="on">
                                    A complete accounting system designed for Indonesian businesses, 
                                    with full tax compliance and real-time reporting built in.
                                </p>
                            </div>
                        </div>
                        
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="service-card-numbered">
                                    <span class="card-number">01</span>
                                    <h3 class="card-title" t-translation="on">Automated P&amp;L Reports</h3>
                                    <p class="card-description" t-translation="on">
                                        Generate accurate profit &amp; loss statements automatically with 
                                        real-time data from all business units.
                                    </p>
                                    <ul class="card-features">
                                        <li t-translation="on">Real-time generation</li>
                                        <li t-translation="on">Multi-entity consolidation</li>
                                        <li t-translation="on">Custom reporting periods</li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="service-card-numbered">
                                    <span class="card-number">02</span>
                                    <h3 class="card-title" t-translation="on">Bank Reconciliation</h3>
                                    <p class="card-description" t-translation="on">
                                        Automatic bank statement import and reconciliation, 
                                        reducing manual errors and saving hours every month.
                                    </p>
                                    <ul class="card-features">
                                        <li t-translation="on">BCA, Mandiri, BNI, BRI support</li>
                                        <li t-translation="on">Auto-matching rules</li>
                                        <li t-translation="on">Exception handling</li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="service-card-numbered">
                                    <span class="card-number">03</span>
                                    <h3 class="card-title" t-translation="on">PPh 21 &amp; BPJS</h3>
                                    <p class="card-description" t-translation="on">
                                        Automated tax calculations compliant with Indonesian 
                                        regulations, including employee income tax and social security.
                                    </p>
                                    <ul class="card-features">
                                        <li t-translation="on">Latest tax regulations</li>
                                        <li t-translation="on">BPJS Kesehatan &amp; Ketenagakerjaan</li>
                                        <li t-translation="on">TER method support</li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="service-card-numbered">
                                    <span class="card-number">04</span>
                                    <h3 class="card-title" t-translation="on">e-Faktur Integration</h3>
                                    <p class="card-description" t-translation="on">
                                        Direct integration with DJP e-Faktur system for seamless 
                                        tax invoice generation and reporting.
                                    </p>
                                    <ul class="card-features">
                                        <li t-translation="on">Auto-generate e-Faktur</li>
                                        <li t-translation="on">Bulk upload support</li>
                                        <li t-translation="on">SPT integration</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- CTA Section -->
                <t t-call="modulio_website.s_modulio_cta_form"/>
            </div>
        </t>
    </template>

    <!-- HR Service Page - Meridian Style -->
