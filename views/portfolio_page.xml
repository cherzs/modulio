<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Portfolio Listing Page - Meridian Style -->
    <template id="portfolio_page" name="Portfolio Page">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'portfolio'"/>
            
            <div id="wrap">
                <!-- Hero Section -->
                <section class="page-hero bg-navy">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-6">
                                <span class="section-label" style="color: var(--modulio-coral);" t-translation="on">Selected Work</span>
                                <h1 class="page-hero-title" t-translation="on">
                                    Outcomes our clients can measure.
                                </h1>
                            </div>
                            <div class="col-lg-5 offset-lg-1 d-flex align-items-center">
                                <p class="page-hero-description mb-0" t-translation="on">
                                    A look at engagements where structured systems thinking 
                                    translated into real, recurring efficiency.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Category Filter -->
                <section class="bg-cream py-4">
                    <div class="container">
                        <div class="d-flex flex-wrap justify-content-center gap-2">
                            <a t-att-href="'/portfolio'" 
                               t-att-class="'btn-text px-4 py-2 ' + ('text-coral' if not current_category else '')"
                               style="text-decoration: none;">
                                <span t-translation="on">All Projects</span>
                            </a>
                            <t t-foreach="categories" t-as="cat">
                                <a t-att-href="'/portfolio?category=' + (cat.slug or str(cat.id))" 
                                   t-att-class="'btn-text px-4 py-2 ' + ('text-coral' if current_category == cat.slug else '')"
                                   style="text-decoration: none;">
                                    <t t-esc="cat.name"/>
                                </a>
                            </t>
                        </div>
                    </div>
                </section>
                
                <!-- Portfolio Grid -->
                <section class="modulio-section bg-white modulio-portfolio-listing">
                    <div class="container">
                        <t t-if="projects">
                            <div class="row g-4">
                                <t t-foreach="projects" t-as="project">
                                    <div class="col-lg-4 col-md-6 d-flex">
                                        <a t-att-href="'/portfolio/' + (project.slug or str(project.id))" class="text-decoration-none d-flex flex-column flex-grow-1 w-100">
                                            <div class="work-card w-100">
                                                <!-- img + card_listing_image_url: QWeb may not call Python methods reliably; inline bg also loses to dark-mode !important -->
                                                <div class="work-image modulio-portfolio-thumb">
                                                    <img t-att-src="project.card_listing_image_url" alt="" loading="lazy" width="600" height="200"/>
                                                </div>
                                                <div class="work-content">
                                                    <t t-if="project.category_id">
                                                        <span class="work-category">
                                                            <t t-esc="project.category_id.name"/>
                                                        </span>
                                                    </t>
                                                    <h3 class="work-title">
                                                        <t t-esc="project.name"/>
                                                    </h3>
                                                    <p class="work-description">
                                                        <t t-esc="project.description"/>
                                                    </p>
                                                    <div class="work-stats">
                                                        <t t-if="project.stat_1_value">
                                                            <div class="work-stat">
                                                                <div class="stat-value"><t t-esc="project.stat_1_value"/></div>
                                                                <div class="stat-label"><t t-esc="project.stat_1_label"/></div>
                                                            </div>
                                                        </t>
                                                        <span class="btn-text ms-auto">
                                                            CASE <span class="arrow">→</span>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="text-center py-5">
                                <div class="section-title mb-3" t-translation="on">No projects found</div>
                                <p class="section-subtitle mx-auto" t-translation="on">Check back soon for new case studies.</p>
                                <a href="/portfolio" class="btn-primary-coral mt-4" t-translation="on">View All Projects</a>
                            </div>
                        </t>
                    </div>
                </section>
                
                <!-- CTA Section -->
                <t t-call="modulio_website.s_modulio_cta_form"/>
            </div>
        </t>
    </template>
    
    <!-- Portfolio Detail Page - Meridian Style -->
    <template id="portfolio_detail_page" name="Portfolio Detail">
        <t t-call="website.layout">
            <t t-set="pageName" t-value="'portfolio-detail'"/>
            
            <div id="wrap">
                <!-- Hero Section (solid navy so light/dark text contrast is correct) -->
                <section class="hero-section bg-navy">
                    <div class="hero-overlay"></div>
                    <div class="container">
                        <div class="row align-items-center">
                            <div class="col-lg-7 hero-content">
                                <t t-if="project.category_id">
                                    <div class="hero-tags">
                                        <span><t t-esc="project.category_id.name"/></span>
                                        <t t-if="project.industry">
                                            <span><t t-esc="project.industry"/></span>
                                        </t>
                                    </div>
                                </t>
                                
                                <h1 class="hero-title">
                                    <t t-esc="project.name"/>
                                </h1>
                                
                                <p class="hero-description">
                                    <t t-esc="project.description"/>
                                </p>
                                
                                <div class="hero-buttons">
                                    <a href="/appointment/1" class="btn-primary-coral" t-translation="on">
                                        Start similar project
                                    </a>
                                    <a href="/portfolio" class="btn-outline-light" t-translation="on">
                                        View all cases <span class="arrow">→</span>
                                    </a>
                                </div>
                            </div>
                            
                            <div class="col-lg-4 offset-lg-1">
                                <t t-if="project.stat_1_value">
                                    <div class="hero-stats">
                                        <div class="stat-item">
                                            <div class="stat-value"><t t-esc="project.stat_1_value"/></div>
                                            <div class="stat-label"><t t-esc="project.stat_1_label"/></div>
                                        </div>
                                        <t t-if="project.stat_2_value">
                                            <div class="stat-item">
                                                <div class="stat-value"><t t-esc="project.stat_2_value"/></div>
                                                <div class="stat-label"><t t-esc="project.stat_2_label"/></div>
                                            </div>
                                        </t>
                                        <t t-if="project.stat_3_value">
                                            <div class="stat-item">
                                                <div class="stat-value"><t t-esc="project.stat_3_value"/></div>
                                                <div class="stat-label"><t t-esc="project.stat_3_label"/></div>
                                            </div>
                                        </t>
                                        <t t-if="project.client_name">
                                            <div class="stat-item">
                                                <div class="stat-label" t-translation="on">CLIENT</div>
                                                <div class="stat-value" style="font-size: 18px;"><t t-esc="project.client_name"/></div>
                                            </div>
                                        </t>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Content Section -->
                <section class="modulio-section bg-cream">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-8">
                                <t t-if="project.image">
                                    <div class="portfolio-detail-cover radius-12 overflow-hidden mb-5" style="box-shadow: 0 20px 40px rgba(0,0,0,0.1);">
                                        <img t-att-src="'/web/image/modulio.portfolio/' + str(project.id) + '/image'"
                                             alt=""
                                             class="img-fluid"/>
                                    </div>
                                </t>
                                
                                <div class="portfolio-content" style="font-size: 17px; line-height: 1.8; color: var(--modulio-text);">
                                    <t t-out="project.content"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                
                <!-- Related Projects -->
                <t t-if="related_projects">
                    <section class="modulio-section bg-white">
                        <div class="container">
                            <div class="row mb-5">
                                <div class="col-lg-6">
                                    <span class="section-label" t-translation="on">Related Work</span>
                                    <h2 class="section-title" t-translation="on">Similar engagements</h2>
                                </div>
                            </div>
                            <div class="row g-4">
                                <t t-foreach="related_projects" t-as="rel_project">
                                    <div class="col-lg-4 col-md-6 d-flex">
                                        <a t-att-href="'/portfolio/' + (rel_project.slug or str(rel_project.id))" class="text-decoration-none d-flex flex-column flex-grow-1 w-100">
                                            <div class="work-card w-100">
                                                <div class="work-image modulio-portfolio-thumb">
                                                    <img t-att-src="rel_project.card_listing_image_url" alt="" loading="lazy" width="600" height="200"/>
                                                </div>
                                                <div class="work-content">
                                                    <t t-if="rel_project.category_id">
                                                        <span class="work-category">
                                                            <t t-esc="rel_project.category_id.name"/>
                                                        </span>
                                                    </t>
                                                    <h3 class="work-title"><t t-esc="rel_project.name"/></h3>
                                                    <p class="work-description"><t t-esc="rel_project.description"/></p>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </section>
                </t>
                
                <!-- CTA Section -->
                <t t-call="modulio_website.s_modulio_cta_form"/>
            </div>
        </t>
    </template>
</odoo>
