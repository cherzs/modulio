<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="modulio_font_assets" inherit_id="website.layout">
        <xpath expr="//head" position="inside">
            <!-- Inter Font - Strict Single Font System -->
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
            <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
            <style>
                /* Force Inter font immediately to prevent FOUT */
                html, body, * { font-family: 'Inter', sans-serif !important; }
            </style>
            <!-- Prevent FOUC for dark mode - runs before body renders -->
            <script>
                (function() {
                    try {
                        if (localStorage.getItem('modulio-theme') === 'dark') {
                            document.documentElement.classList.add('dark-mode');
                            document.documentElement.style.backgroundColor = '#0d1f2d';
                        }
                    } catch(e) {}
                })();
            </script>
        </xpath>
    </template>

    <template id="modulio_header_replace" inherit_id="website.layout" priority="99">
        <xpath expr="//header" position="replace">
            <header id="modulioNavbar" class="o_main_header">
                <div class="container">
                    <nav class="navbar navbar-expand-lg p-0 align-items-center">
                        <!-- Brand - Using Odoo's website logo -->
                        <a class="navbar-brand d-flex align-items-center" href="/">
                            <t t-set="website" t-value="request.website"/>
                            <t t-if="website.logo">
                                <img t-att-src="'/web/image/website/%s/logo' % website.id" 
                                     alt="Logo" 
                                     class="navbar-logo"
                                     style="height: 40px; width: auto;"/>
                            </t>
                            <t t-else="">
                                <span class="brand-dot"></span>
                                <span t-esc="website.name or 'Modulio'"/>
                            </t>
                        </a>
                        
                        <button class="navbar-toggler border-0 shadow-none p-2" type="button" data-bs-toggle="collapse" data-bs-target="#modulioNav">
                            <span class="navbar-toggler-icon" style="filter: brightness(0) invert(1);"/>
                        </button>

                        <div class="collapse navbar-collapse" id="modulioNav">
                            <ul class="navbar-nav ms-auto align-items-center" style="gap: 4px;">
                                <li class="nav-item">
                                    <a class="nav-link" href="/services" t-translation="on">Services</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/#approach" t-translation="on">Approach</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/portfolio" t-translation="on">Work</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/#contact" t-translation="on">Contact</a>
                                </li>

                                <!-- Language Selector -->
                                <li class="nav-item dropdown ms-2">
                                    <t t-set="languages" t-value="request.website.language_ids"/>
                                    <t t-set="current_lang_code" t-value="request.env.lang or 'en_US'"/>
                                    <a class="nav-link dropdown-toggle lang-selector" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <t t-foreach="languages" t-as="lg">
                                            <t t-if="lg.code == current_lang_code"><t t-esc="lg.code[:2].upper()"/></t>
                                        </t>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end lang-dropdown">
                                        <t t-foreach="languages" t-as="lg">
                                            <li>
                                                <a t-attf-class="dropdown-item #{'active' if lg.code == current_lang_code else ''}" 
                                                   t-attf-href="/{{ lg.url_code }}{{ request.httprequest.path }}">
                                                    <t t-esc="lg.name"/>
                                                </a>
                                            </li>
                                        </t>
                                    </ul>
                                </li>

                                <!-- Theme Toggle -->
                                <li class="nav-item ms-2">
                                    <button class="theme-toggle" type="button" aria-label="Toggle theme">
                                        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="5"></circle>
                                            <line x1="12" y1="1" x2="12" y2="3"></line>
                                            <line x1="12" y1="21" x2="12" y2="23"></line>
                                            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                                            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                                            <line x1="1" y1="12" x2="3" y2="12"></line>
                                            <line x1="21" y1="12" x2="23" y2="12"></line>
                                            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                                            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                                        </svg>
                                        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                                        </svg>
                                    </button>
                                </li>

                                <li class="nav-item ms-2">
                                    <a href="/appointment/1" class="btn-primary-coral" t-translation="on">Book consultation</a>
                                </li>
                            </ul>
                        </div>
                    </nav>
                </div>
            </header>
        </xpath>
    </template>

    <!-- Floating WhatsApp Button -->
    <template id="modulio_whatsapp_button" inherit_id="website.layout" priority="99">
        <xpath expr="//main" position="after">
            <div class="floating-whatsapp">
                <a href="https://wa.me/6285675666627?text=Halo%20Modulio%2C%20saya%20tertarik%20untuk%20konsultasi%20mengenai%20Odoo." 
                   target="_blank" 
                   rel="noopener noreferrer"
                   aria-label="Chat via WhatsApp">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                    </svg>
                </a>
            </div>
        </xpath>
    </template>

    <!-- Minimal Footer - Meridian Style -->
    <template id="modulio_footer_replace" inherit_id="website.layout" priority="99">
        <xpath expr="//footer" position="replace">
            <footer class="footer-minimal">
                <div class="container">
                    <div class="row align-items-center">
                        <!-- Left: Brand + Tagline -->
                        <div class="col-md-6 mb-3 mb-md-0">
                            <div class="d-flex align-items-center gap-3">
                                <t t-set="website" t-value="request.website"/>
                                <a href="/" class="footer-brand text-decoration-none">
                                    <t t-if="website.logo">
                                        <img t-att-src="'/web/image/website/%s/logo' % website.id" 
                                             alt="Logo" 
                                             style="height: 32px; width: auto; filter: brightness(0) invert(1);"/>
                                    </t>
                                    <t t-else="">
                                        <span class="brand-dot"></span>
                                        <span t-esc="website.name or 'Modulio'"/>
                                    </t>
                                </a>
                                <span class="footer-tagline" t-translation="on">Accounting systems · Odoo · Integrations</span>
                            </div>
                        </div>
                        
                        <!-- Right: Copyright -->
                        <div class="col-md-6 text-md-end">
                            <span class="footer-copyright">© <t t-esc="datetime.datetime.now().year"/> <t t-esc="website.name or 'Modulio'"/>. <span t-translation="on">All rights reserved.</span></span>
                        </div>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>
</odoo>
