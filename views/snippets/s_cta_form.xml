<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- CTA Section - Gradient with Contact Form -->
    <template id="s_modulio_cta_form" name="CTA Section">
        <section class="modulio-section bg-cream" id="contact">
            <div class="container">
                <div class="cta-section">
                    <div class="row">
                        <!-- Left Content -->
                        <div class="col-lg-5 mb-4 mb-lg-0">
                            <span class="section-label" style="color: var(--modulio-coral);" t-translation="on">Begin a Conversation</span>
                            <h2 class="cta-title" t-translation="on">
                                Let's design the system your finance team deserves.
                            </h2>
                            <p class="cta-description" t-translation="on">
                                A 30-minute consultation with a senior partner. We'll review your 
                                current stack, identify the highest-leverage improvements, and 
                                outline a path forward — no obligation.
                            </p>
                            
                            <!-- Contact Info -->
                            <div class="cta-info mt-4">
                                <div class="info-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                        <polyline points="22,6 12,13 2,6"/>
                                    </svg>
                                    <a href="mailto:hello@modulio.id">hello@modulio.id</a>
                                </div>
                                <div class="info-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                                    </svg>
                                    <a href="tel:+6285675666627">+62 856 7566 6627</a>
                                </div>
                                <div class="info-item">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                                        <circle cx="12" cy="10" r="3"/>
                                    </svg>
                                    <span>Jakarta · Surabaya</span>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Right Contact Form -->
                        <div class="col-lg-6 offset-lg-1">
                            <div class="cta-form-box">
                                <h3 class="form-title" t-translation="on">Send us a message</h3>
                                <form action="/contact/submit" method="post" class="contact-form">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                    
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label" t-translation="on">Your Name</label>
                                            <input type="text" name="contact_name" class="form-control" required="required" placeholder="John Doe"/>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label" t-translation="on">Company</label>
                                            <input type="text" name="company_name" class="form-control" placeholder="Company Name"/>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label" t-translation="on">Email</label>
                                            <input type="email" name="email" class="form-control" required="required" placeholder="john@company.com"/>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label" t-translation="on">Phone</label>
                                            <input type="tel" name="phone" class="form-control" placeholder="+62 812 3456 7890"/>
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label class="form-label" t-translation="on">How can we help?</label>
                                        <textarea name="message" class="form-control" rows="4" required="required" placeholder="Tell us about your project..."></textarea>
                                    </div>
                                    
                                    <button type="submit" class="btn-primary-coral w-100 justify-content-center">
                                        <span t-translation="on">Send Message</span>
                                        <span class="arrow">→</span>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
