<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- How We Work Section - Meridian Style -->
    <template id="s_modulio_process" name="How We Work">
        <section class="modulio-section bg-cream" id="approach">
            <div class="container">
                <!-- Header -->
                <div class="row mb-5">
                    <div class="col-lg-5">
                        <span class="section-label" t-translation="on">How We Work</span>
                        <h2 class="section-title" t-translation="on">
                            A structured approach to every engagement.
                        </h2>
                    </div>
                    <div class="col-lg-6 offset-lg-1 d-flex align-items-center">
                        <p class="section-subtitle mb-0" t-translation="on">
                            We follow a proven methodology that ensures predictable delivery, 
                            clear communication, and measurable outcomes.
                        </p>
                    </div>
                </div>
                
                <!-- Process Steps -->
                <div class="row g-4">
                    <!-- Step 1 -->
                    <div class="col-md-6 col-lg-3">
                        <div class="process-card">
                            <div class="process-number">01</div>
                            <h3 class="process-title" t-translation="on">Discovery</h3>
                            <p class="process-description" t-translation="on">
                                We map your current systems, pain points, and goals. 
                                No assumptions — just thorough analysis.
                            </p>
                            <ul class="process-list">
                                <li t-translation="on">Stakeholder interviews</li>
                                <li t-translation="on">Process documentation</li>
                                <li t-translation="on">Gap analysis</li>
                            </ul>
                        </div>
                    </div>
                    
                    <!-- Step 2 -->
                    <div class="col-md-6 col-lg-3">
                        <div class="process-card">
                            <div class="process-number">02</div>
                            <h3 class="process-title" t-translation="on">Design</h3>
                            <p class="process-description" t-translation="on">
                                We architect the solution with you, ensuring every 
                                workflow matches how your team actually works.
                            </p>
                            <ul class="process-list">
                                <li t-translation="on">Solution architecture</li>
                                <li t-translation="on">Workflow design</li>
                                <li t-translation="on">Technical specification</li>
                            </ul>
                        </div>
                    </div>
                    
                    <!-- Step 3 -->
                    <div class="col-md-6 col-lg-3">
                        <div class="process-card">
                            <div class="process-number">03</div>
                            <h3 class="process-title" t-translation="on">Build</h3>
                            <p class="process-description" t-translation="on">
                                We implement in sprints with regular demos. 
                                You see progress every week, not just at the end.
                            </p>
                            <ul class="process-list">
                                <li t-translation="on">Agile development</li>
                                <li t-translation="on">Weekly demos</li>
                                <li t-translation="on">Iterative refinement</li>
                            </ul>
                        </div>
                    </div>
                    
                    <!-- Step 4 -->
                    <div class="col-md-6 col-lg-3">
                        <div class="process-card">
                            <div class="process-number">04</div>
                            <h3 class="process-title" t-translation="on">Launch</h3>
                            <p class="process-description" t-translation="on">
                                We train your team, migrate data, and go live 
                                with full support. The system runs without us.
                            </p>
                            <ul class="process-list">
                                <li t-translation="on">Team training</li>
                                <li t-translation="on">Data migration</li>
                                <li t-translation="on">Go-live support</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
