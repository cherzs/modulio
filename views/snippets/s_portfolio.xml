<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portfolio/Work Section - Card Style with Stats -->
    <template id="s_modulio_portfolio" name="Portfolio Preview">
        <section class="modulio-section bg-white">
            <div class="container">
                <!-- Header -->
                <div class="row mb-5">
                    <div class="col-lg-6">
                        <span class="section-label" t-translation="on">Selected Work</span>
                        <h2 class="section-title" t-translation="on">
                            Outcomes our clients can measure.
                        </h2>
                    </div>
                    <div class="col-lg-5 offset-lg-1 d-flex align-items-center">
                        <p class="section-subtitle mb-0" t-translation="on">
                            A look at engagements where structured systems thinking 
                            translated into real, recurring efficiency.
                        </p>
                    </div>
                </div>
                
                <!-- Work Cards -->
                <div class="row g-4">
                    <!-- Card 1 -->
                    <div class="col-lg-4 col-md-6">
                        <a href="/portfolio/manufacturing-erp" class="text-decoration-none">
                            <div class="work-card">
                                <div class="work-image oe_img_bg o_bg_img_center" 
                                     style="background-image: url('/web/image/website.library_image_08');">
                                </div>
                                <div class="work-content">
                                    <span class="work-category" t-translation="on">Manufacturing</span>
                                    <h3 class="work-title" t-translation="on">
                                        Closing the books in five days, not twenty.
                                    </h3>
                                    <p class="work-description" t-translation="on">
                                        Replaced spreadsheet-driven consolidation with a unified Odoo 
                                        deployment across four legal entities.
                                    </p>
                                    <div class="work-stats">
                                        <div class="work-stat">
                                            <div class="stat-value">75%</div>
                                            <div class="stat-label" t-translation="on">faster month-end close</div>
                                        </div>
                                        <span class="btn-text">
                                            CASE <span class="arrow">→</span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    
                    <!-- Card 2 -->
                    <div class="col-lg-4 col-md-6">
                        <a href="/portfolio/professional-services" class="text-decoration-none">
                            <div class="work-card">
                                <div class="work-image oe_img_bg o_bg_img_center" 
                                     style="background-image: url('/web/image/website.library_image_10');">
                                </div>
                                <div class="work-content">
                                    <span class="work-category" t-translation="on">Professional Services</span>
                                    <h3 class="work-title" t-translation="on">
                                        Removing 1,200 manual entries per month.
                                    </h3>
                                    <p class="work-description" t-translation="on">
                                        Designed approval flows and bank reconciliation rules that 
                                        eliminated repetitive accounting work.
                                    </p>
                                    <div class="work-stats">
                                        <div class="work-stat">
                                            <div class="stat-value">1.2k</div>
                                            <div class="stat-label" t-translation="on">manual entries automated</div>
                                        </div>
                                        <span class="btn-text">
                                            CASE <span class="arrow">→</span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    
                    <!-- Card 3 -->
                    <div class="col-lg-4 col-md-6">
                        <a href="/portfolio/ecommerce-integration" class="text-decoration-none">
                            <div class="work-card">
                                <div class="work-image oe_img_bg o_bg_img_center" 
                                     style="background-image: url('/web/image/website.library_image_13');">
                                </div>
                                <div class="work-content">
                                    <span class="work-category" t-translation="on">E-Commerce</span>
                                    <h3 class="work-title" t-translation="on">
                                        One source of truth across five platforms.
                                    </h3>
                                    <p class="work-description" t-translation="on">
                                        Connected storefront, payments, 3PL, CRM, and accounting 
                                        through a single integration layer.
                                    </p>
                                    <div class="work-stats">
                                        <div class="work-stat">
                                            <div class="stat-value">5</div>
                                            <div class="stat-label" t-translation="on">systems unified</div>
                                        </div>
                                        <span class="btn-text">
                                            CASE <span class="arrow">→</span>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
                
                <!-- View All Button -->
                <div class="text-center mt-5">
                    <a href="/portfolio" class="btn-primary-coral" t-translation="on">
                        View all case studies <span class="arrow">→</span>
                    </a>
                </div>
            </div>
        </section>
    </template>
</odoo>
