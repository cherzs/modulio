<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Portfolio/Work Section — records with is_landing_page (max 3 enforced in backend) -->
    <template id="s_modulio_portfolio" name="Portfolio Preview">
        <t t-set="lp_projects" t-value="request.env['modulio.portfolio'].sudo().search([('website_published', '=', True), ('is_landing_page', '=', True)], order='sequence, id desc', limit=3)"/>
        <section class="modulio-section bg-white">
            <div class="container">
                <!-- Header -->
                <div class="row mb-5">
                    <div class="col-lg-6">
                        <span class="section-label" t-translation="on">Selected Work</span>
                        <h2 class="section-title" t-translation="on">
                            Outcomes our clients can measure.
                        </h2>
                    </div>
                    <div class="col-lg-5 offset-lg-1 d-flex align-items-center">
                        <p class="section-subtitle mb-0" t-translation="on">
                            A look at engagements where structured systems thinking
                            translated into real, recurring efficiency.
                        </p>
                    </div>
                </div>

                <!-- Work Cards (dynamic, max 3) -->
                <div class="row g-4" t-if="lp_projects">
                    <t t-foreach="lp_projects" t-as="project">
                        <div class="col-lg-4 col-md-6">
                            <a t-att-href="'/portfolio/' + (project.slug or str(project.id))" class="text-decoration-none">
                                <div class="work-card">
                                    <div class="work-image oe_img_bg o_bg_img_center"
                                         t-attf-style="background-image: url('{{ project.card_listing_image_url }}');">
                                    </div>
                                    <div class="work-content">
                                        <t t-if="project.category_id">
                                            <span class="work-category">
                                                <t t-esc="project.category_id.name"/>
                                            </span>
                                        </t>
                                        <h3 class="work-title">
                                            <t t-esc="project.name"/>
                                        </h3>
                                        <p class="work-description">
                                            <t t-esc="project.description"/>
                                        </p>
                                        <div class="work-stats">
                                            <t t-if="project.stat_1_value">
                                                <div class="work-stat">
                                                    <div class="stat-value"><t t-esc="project.stat_1_value"/></div>
                                                    <div class="stat-label"><t t-esc="project.stat_1_label"/></div>
                                                </div>
                                            </t>
                                            <span class="btn-text">
                                                CASE <span class="arrow">→</span>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </t>
                </div>

                <!-- View All Button -->
                <div class="text-center mt-5">
                    <a href="/portfolio" class="btn-primary-coral" t-translation="on">
                        View all case studies <span class="arrow">→</span>
                    </a>
                </div>
            </div>
        </section>
    </template>
</odoo>
