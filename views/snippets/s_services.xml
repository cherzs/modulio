<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Services — records with is_landing_page (max 4 enforced in backend) -->
    <template id="s_modulio_services" name="Services Section">
        <t t-set="ls_services" t-value="request.env['modulio.service'].sudo().search([('website_published', '=', True), ('is_landing_page', '=', True)], order='sequence, id', limit=4)"/>
        <section class="modulio-section bg-cream">
            <div class="container">
                <!-- Header -->
                <div class="row mb-5">
                    <div class="col-lg-5">
                        <span class="section-label" t-translation="on">Our Services</span>
                        <h2 class="section-title">
                            <span t-translation="on">A focused practice across</span>
                            <span t-translation="on"> four disciplines.</span>
                        </h2>
                    </div>
                    <div class="col-lg-6 offset-lg-1 d-flex align-items-center">
                        <p class="section-subtitle mb-0" t-translation="on">
                            We work where finance, operations, and engineering meet — designing the
                            systems that quietly run modern businesses. Each engagement is led by
                            senior consultants and shaped to your operating model.
                        </p>
                    </div>
                </div>

                <!-- Service Cards -->
                <div class="row g-4" t-if="ls_services">
                    <t t-foreach="ls_services" t-as="svc">
                        <div class="col-md-6">
                            <a t-att-href="'/services/' + (svc.slug or '')" class="text-decoration-none">
                                <div class="service-card-numbered">
                                    <span class="card-number"><t t-esc="svc.card_number or ''"/></span>
                                    <h3 class="card-title">
                                        <t t-esc="svc.name"/>
                                    </h3>
                                    <p class="card-description">
                                        <t t-esc="svc.short_description"/>
                                    </p>
                                    <ul class="card-features">
                                        <t t-if="svc.feature_1">
                                            <li><t t-esc="svc.feature_1"/></li>
                                        </t>
                                        <t t-if="svc.feature_2">
                                            <li><t t-esc="svc.feature_2"/></li>
                                        </t>
                                        <t t-if="svc.feature_3">
                                            <li><t t-esc="svc.feature_3"/></li>
                                        </t>
                                    </ul>
                                </div>
                            </a>
                        </div>
                    </t>
                </div>
            </div>
        </section>
    </template>
</odoo>
