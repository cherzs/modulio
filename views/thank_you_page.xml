<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Thank You Page after Contact Form Submission -->
    <template id="contact_thank_you_page" name="Contact Thank You">
        <t t-call="website.layout">
            <div id="wrap">
                <section class="thank-you-section">
                    <div class="container">
                        <div class="thank-you-content text-center">
                            <div class="thank-you-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                                    <polyline points="22 4 12 14.01 9 11.01"/>
                                </svg>
                            </div>
                            <h1 class="thank-you-title" t-translation="on">Thank You!</h1>
                            <p class="thank-you-message" t-translation="on">
                                Your message has been sent successfully. Our team will get back to you within 24 hours.
                            </p>
                            <div class="thank-you-actions">
                                <a href="/" class="btn-primary-coral" t-translation="on">
                                    Back to Home
                                </a>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
