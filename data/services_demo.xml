        <record id="service_demo_accounting" model="modulio.service">
            <field name="name">Accounting setup with Odoo</field>
            <field name="slug">accounting</field>
            <field name="sequence">10</field>
            <field name="card_number">01</field>
            <field name="website_published">True</field>
            <field name="is_landing_page">True</field>
            <field name="tag_1">Accounting</field>
            <field name="tag_2">Tax</field>
            <field name="tag_3">Compliance</field>
            <field name="short_description">Chart of accounts, tax structure, multi-entity, and reporting tailored to your business — implemented on Odoo with discipline.</field>
            <field name="feature_1">Localized compliance</field>
            <field name="feature_2">Multi-currency</field>
            <field name="feature_3">Audit-ready reporting</field>
            <field name="stat_1_value">75%</field>
            <field name="stat_1_label">faster month-end close</field>
            <field name="stat_2_value">100%</field>
            <field name="stat_2_label">tax compliance</field>
            <field name="stat_3_value">1.2k</field>
            <field name="stat_3_label">entries automated</field>
            <field name="stat_4_value">24/7</field>
            <field name="stat_4_label">financial visibility</field>
            <field name="content"><![CDATA[
<section class="modulio-section"><div class="container">
<p>We implement chart of accounts, tax structure, multi-entity reporting, and compliance workflows on Odoo — tailored to Indonesian regulations and your operating model.</p>
<p><strong>Typical scope:</strong> automated P&amp;L, bank reconciliation, PPh 21 &amp; BPJS, and e-Faktur integration with DJP.</p>
</div></section>
            ]]></field>
        </record>

