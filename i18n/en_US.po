#. module: modulio_website
#: model:modulio.portfolio,content:modulio_website.portfolio_project_6
msgid ""
"\n"
"                <h2>The Challenge</h2>\n"
"                <p>A logistics company with 50+ vehicles had no visibility into fleet costs. Fuel theft was suspected, maintenance was reactive, and driver performance couldn't be measured.</p>\n"
"                \n"
"                <h2>Our Approach</h2>\n"
"                <p>We built an integrated fleet management solution:</p>\n"
"                <ul>\n"
"                    <li>GPS tracking integration with Odoo</li>\n"
"                    <li>Fuel consumption monitoring and alerts</li>\n"
"                    <li>Preventive maintenance scheduling</li>\n"
"                    <li>Driver performance scorecards</li>\n"
"                    <li>Cost allocation to jobs/customers</li>\n"
"                </ul>\n"
"                \n"
"                <h2>The Results</h2>\n"
"                <ul>\n"
"                    <li>Fuel costs reduced by 18%</li>\n"
"                    <li>Maintenance downtime reduced by 40%</li>\n"
"                    <li>Full cost visibility per vehicle and job</li>\n"
"                </ul>\n"
"            "
msgstr ""

#. module: modulio_website
#: model:modulio.portfolio,content:modulio_website.portfolio_project_2
msgid ""
"\n"
"                <h2>The Challenge</h2>\n"
"                <p>A professional services firm with 50+ employees was drowning in manual data entry. Their accounting team spent most of their time on repetitive tasks instead of analysis and strategy.</p>\n"
"                \n"
"                <h2>Our Approach</h2>\n"
"                <p>We automated their entire financial workflow:</p>\n"
"                <ul>\n"
"                    <li>Smart bank reconciliation with auto-matching rules</li>\n"
"                    <li>Automated expense approval workflows</li>\n"
"                    <li>Invoice generation from timesheets</li>\n"
"                    <li>Recurring journal entries for fixed costs</li>\n"
"                </ul>\n"
"                \n"
"                <h2>The Results</h2>\n"
"                <ul>\n"
"                    <li>1,200 manual entries eliminated monthly</li>\n"
"                    <li>Accounting team capacity freed for analysis</li>\n"
"                    <li>98% reduction in data entry errors</li>\n"
"                    <li>Real-time cash flow visibility</li>\n"
"                </ul>\n"
"            "
msgstr ""

#. module: modulio_website
#: model:modulio.portfolio,content:modulio_website.portfolio_project_5
msgid ""
"\n"
"                <h2>The Challenge</h2>\n"
"                <p>A retail chain with 8 locations struggled with inventory visibility. Stock-outs at one location while excess inventory sat at another was common.</p>\n"
"                \n"
"                <h2>Our Approach</h2>\n"
"                <p>We implemented unified inventory management:</p>\n"
"                <ul>\n"
"                    <li>Real-time inventory sync across all locations</li>\n"
"                    <li>Automated inter-warehouse transfer suggestions</li>\n"
"                    <li>Reorder point automation</li>\n"
"                    <li>Barcode scanning integration</li>\n"
"                </ul>\n"
"                \n"
"                <h2>The Results</h2>\n"
"                <ul>\n"
"                    <li>Stock-out incidents reduced by 80%</li>\n"
"                    <li>Inventory carrying costs reduced by 25%</li>\n"
"                    <li>Real-time visibility across 8 locations</li>\n"
"                </ul>\n"
"            "
msgstr ""

#. module: modulio_website
#: model:modulio.portfolio,content:modulio_website.portfolio_project_1
msgid ""
"\n"
"                <h2>The Challenge</h2>\n"
"                <p>PT Maju Bersama, a mid-market manufacturer with four legal entities, was struggling with month-end close. Their finance team spent 20 days every month manually consolidating data from multiple spreadsheets, leading to delays in financial reporting and decision-making.</p>\n"
"                \n"
"                <h2>Our Approach</h2>\n"
"                <p>We implemented a unified Odoo ERP system across all four entities with:</p>\n"
"                <ul>\n"
"                    <li>Centralized chart of accounts with inter-company mapping</li>\n"
"                    <li>Automated consolidation rules for real-time reporting</li>\n"
"                    <li>Bank reconciliation automation for 3 major Indonesian banks</li>\n"
"                    <li>Custom dashboards for management visibility</li>\n"
"                </ul>\n"
"                \n"
"                <h2>The Results</h2>\n"
"                <p>Within 3 months of go-live, the finance team achieved:</p>\n"
"                <ul>\n"
"                    <li>Month-end close reduced from 20 days to 5 days</li>\n"
"                    <li>75% faster financial reporting</li>\n"
"                    <li>Zero manual consolidation errors</li>\n"
"                    <li>Real-time visibility across all entities</li>\n"
"                </ul>\n"
"            "
msgstr ""

#. module: modulio_website
#: model:modulio.portfolio,content:modulio_website.portfolio_project_3
msgid ""
"\n"
"                <h2>The Challenge</h2>\n"
"                <p>Retail Sukses Indonesia operated across 5 different platforms: Shopify storefront, Midtrans payments, a 3PL provider, separate CRM, and manual accounting in spreadsheets. Data silos caused inventory issues and customer service delays.</p>\n"
"                \n"
"                <h2>Our Approach</h2>\n"
"                <p>We built a unified Odoo system with custom integrations:</p>\n"
"                <ul>\n"
"                    <li>Real-time sync with Shopify orders and inventory</li>\n"
"                    <li>Midtrans payment reconciliation</li>\n"
"                    <li>3PL fulfillment tracking integration</li>\n"
"                    <li>Unified customer data and history</li>\n"
"                    <li>Automated accounting entries</li>\n"
"                </ul>\n"
"                \n"
"                <h2>The Results</h2>\n"
"                <ul>\n"
"                    <li>5 systems unified into one platform</li>\n"
"                    <li>Inventory accuracy improved to 99.5%</li>\n"
"                    <li>Customer service response time cut by 60%</li>\n"
"                    <li>Complete order visibility from click to delivery</li>\n"
"                </ul>\n"
"            "
msgstr ""

#. module: modulio_website
#: model:modulio.portfolio,content:modulio_website.portfolio_project_4
msgid ""
"\n"
"                <h2>The Challenge</h2>\n"
"                <p>Teknologi Nusantara's HR team spent 2 full days processing payroll for 200+ employees. Manual calculations led to errors and employee complaints.</p>\n"
"                \n"
"                <h2>Our Approach</h2>\n"
"                <p>We implemented a complete HR and payroll automation:</p>\n"
"                <ul>\n"
"                    <li>Employee self-service portal for leave and expenses</li>\n"
"                    <li>Automated attendance tracking integration</li>\n"
"                    <li>PPh 21 calculation with TER method</li>\n"
"                    <li>BPJS Kesehatan &amp; Ketenagakerjaan auto-calculation</li>\n"
"                    <li>Direct bank transfer file generation</li>\n"
"                </ul>\n"
"                \n"
"                <h2>The Results</h2>\n"
"                <ul>\n"
"                    <li>Payroll processing reduced to 15 minutes</li>\n"
"                    <li>Zero calculation errors</li>\n"
"                    <li>100% labor law compliance</li>\n"
"                    <li>Employee satisfaction increased</li>\n"
"                </ul>\n"
"            "
msgstr ""

